# Password to access the web dashboard
DASHBOARD_PASSWORD=changeme

# Admin password printed on the bottom of your T-Mobile gateway
GATEWAY_PASSWORD=your_gateway_admin_password

# Gateway IP — direct (192.168.12.1) or relay (10.x.x.x:3334)
# GATEWAY_IP=192.168.12.1

# Shared secret between dashboard server and relay (optional, must match on both)
# RELAY_SECRET=some_random_string

# Server port (default: 3333)
# PORT=3333
